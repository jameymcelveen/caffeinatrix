{
  "name": "caffeinatrix",
  "productName": "Caffeinatrix",
  "version": "1.0.0",
  "description": "A fullscreen Matrix rain that keeps your Mac or PC awake while your long jobs run.",
  "main": "main.js",
  "author": "Jamey",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.caffeinatrix.app",
    "productName": "Caffeinatrix",
    "copyright": "Copyright (c) 2026 Jamey",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "build/icon.png"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Caffeinatrix"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Caffeinatrix"
    }
  }
}
